# Copy this file to .env.local and fill in the secrets below.
#
#   cp .env.example .env.local
#
# docker-compose reads .env.local and will not start without it.
#
# Generate the three required secrets in one go:
#
#   echo "ENCRYPTION_KEY=$(openssl rand -base64 32)"
#   echo "BETTER_AUTH_SECRET=$(openssl rand -hex 32)"
#   echo "CSRF_SECRET=$(openssl rand -hex 32)"
#
# =============================================================================
# REQUIRED — the app refuses to start without these
# =============================================================================

# Encrypts user-supplied provider API keys at rest (AES-256-GCM).
# Must be exactly 32 bytes, base64-encoded: openssl rand -base64 32
# Changing this makes every already-stored user API key undecryptable.
ENCRYPTION_KEY=

# Signs sessions. Any long random string: openssl rand -hex 32
# Changing this signs every existing user out.
BETTER_AUTH_SECRET=

# Signs CSRF tokens. Any long random string: openssl rand -hex 32
CSRF_SECRET=

# Public base URL of the app. Used to build OAuth callback URLs, so it must
# match what you registered with Google/GitHub. Your real domain in production.
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# SOCIAL SIGN-IN — optional
# =============================================================================
# Email/password sign-in and sign-up is always enabled, so you can leave this
# whole section empty. A provider is only enabled when BOTH of its variables
# are set, and the sign-in UI hides providers that aren't configured.

# Callback URL to register:  {BETTER_AUTH_URL}/api/auth/callback/google
# Create at: https://console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Callback URL to register:  {BETTER_AUTH_URL}/api/auth/callback/github
# Create at: https://github.com/settings/developers -> New OAuth App
# (Unrelated to GITHUB_TOKEN further down, which is for developer tools.)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# INFRASTRUCTURE
# =============================================================================
# Using Docker? Skip this section — docker-compose overrides all of it with the
# compose network's own hostnames. These values are for running `npm run dev`
# against services you host yourself.

DATABASE_URL=postgres://zola:zola@localhost:5432/zola

# MINIO_ENDPOINT/MINIO_PORT are server-side only. MINIO_PUBLIC_URL is the
# browser-reachable base URL for uploaded files — point it at your real domain
# in production (e.g. https://storage.example.com); localhost:9000 only works
# when the app and the browser are on the same machine.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=zola
MINIO_SECRET_KEY=zola-minio-secret
MINIO_BUCKET=chat-attachments
MINIO_PUBLIC_URL=http://localhost:9000

# =============================================================================
# AI PROVIDERS — all optional
# =============================================================================
# Users can add their own keys in Settings > API Keys (encrypted at rest), so
# none of these are required. Set them only to preconfigure a provider.

OPENAI_API_KEY=
MISTRAL_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=

# Local models via Ollama. In Docker use host.docker.internal instead of
# localhost to reach an Ollama running on the host machine.
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# OPTIONAL
# =============================================================================

# Developer tools
EXA_API_KEY=
GITHUB_TOKEN=

# Production deployment
NEXT_PUBLIC_VERCEL_URL=

# Set to true to run the bundle analyzer on next build
ANALYZE=false
